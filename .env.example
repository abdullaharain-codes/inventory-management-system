DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=inventory_db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Flask
SECRET_KEY=change-this-to-another-random-secret
FLASK_ENV=development
FLASK_DEBUG=True

# Security
# Set IS_PRODUCTION=True in production to enforce HTTPS-only cookies (Secure flag)
IS_PRODUCTION=False
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
